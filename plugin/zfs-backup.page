  // Stunden 00–23 / Minuten 00–59 als Auswahloptionen (Wert = Zahl, Anzeige 2-stellig).
  $hourOpts = '';
  for ($h = 0; $h < 24; $h++) { $hourOpts .= '<option value="'.$h.'">'.str_pad((string)$h,2,'0',STR_PAD_LEFT).'</option>'; }
  $minOpts = '';
  for ($m = 0; $m < 60; $m++) { $minOpts .= '<option value="'.$m.'">'.str_pad((string)$m,2,'0',STR_PAD_LEFT).'</option>'; }

  $smd  = "#### Zeitplan\n\n";
  $smd .= zb_ed_md('Automatisch ausführen',
            'Startet den Backup-Lauf geplant über Unraids Cron. Aus = kein Zeitplan.',
