      // der den Button sonst streckt. width:fit-content (kein Strecken in Block/
      // Grid) + flex:0 0 auto (kein Wachsen im Flex) + justify-self:start, alles
      // inline-!important, deckt alle Layout-Fälle ab.
      $st = 'width:fit-content !important;flex:0 0 auto !important;justify-self:start !important';
      return '<button type="button" class="' . $cls . '" style="' . $st . '"'
           . ' data-act="' . zb_a($act) . '" data-title="' . zb_a($title) . '"'
