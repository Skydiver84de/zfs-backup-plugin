  // Aktionen pro Zeile (Delegation, da Zeilen serverseitig gerendert sind).
  // WICHTIG: nur die Ziel-Tabelle in DIESEM Panel – sonst greift querySelector
  // die erste .zb-tg (z. B. die Kapazitäts-Tabelle auf der Status-Seite) und die
  // Ziele-Knöpfe bekommen keine Handler.
  var tgTable = document.querySelector('[data-panel="targets"] .zb-tg');
  if (tgTable) {
    tgTable.addEventListener('click', function(ev){
      var tr = ev.target.closest('tr[data-id]');
      if (!tr) return;
      var id = tr.dataset.id;

      if (ev.target.classList.contains('zb-test')) {
        var btn = ev.target;
        btn.disabled = true;
        rowMsg(tr, true, 'Teste …');
        var body = 'csrf_token=' + encodeURIComponent(zbCsrf()) +
                   '&action=test&id=' + encodeURIComponent(id);
        zbStream(TG_URL, body, 'Test: ' + id, 'Test läuft …\n\n').then(function(text){
          btn.disabled = false;
          var ok = /\[Exit-Code: 0\]/.test(text);
          zbModalStatus(ok);
          rowMsg(tr, ok, ok ? 'erreichbar' : 'nicht erreichbar');
        }).catch(function(e){
          btn.disabled = false;
          zbModalBody('Fehler beim Test: ' + e);
          zbModalStatus(false);
          rowMsg(tr, false, 'Fehler');
        });
      }

      if (ev.target.classList.contains('zb-del')) {
        if (!confirm('Ziel "' + id + '" wirklich löschen?')) return;
        ev.target.disabled = true;
        zbPost(TG_URL, { action:'delete', id:id }).then(function(r){
          if (r.data && r.data.ok) { location.hash = 'targets'; location.reload(); }
          else { ev.target.disabled = false; rowMsg(tr, false, (r.data && (r.data.msg || r.data.error)) || 'Fehler'); }
        });
      }

      // Reihenfolge ändern (= Backup-Reihenfolge): eine Position hoch/runter.
      if (ev.target.classList.contains('zb-up') || ev.target.classList.contains('zb-down')) {
        var dir = ev.target.classList.contains('zb-up') ? 'up' : 'down';
        ev.target.disabled = true;
        rowMsg(tr, true, 'Verschiebe …');
        zbPost(TG_URL, { action:'move', id:id, dir:dir }).then(function(r){
          if (r.data && r.data.ok) { location.hash = 'targets'; location.reload(); }
          else { ev.target.disabled = false; rowMsg(tr, false, (r.data && (r.data.msg || r.data.error)) || 'Fehler'); }
        });
      }
    });

    // --- Editor (Bearbeiten) ------------------------------------------
    // Schlüssel-Feld beim Öffnen aus dem vorhandenen SSH_OPTIONS vorbefüllen.
    function sshFill(er){
      var keyInp = er.querySelector('[data-ssh="key"]');
      if (!keyInp) return;
      keyInp.value = sshKeyOf(er.getAttribute('data-orig-ssh') || '');
    }

    function saveEdit(er, btn){
      var id  = er.dataset.editId;
      var msg = er.querySelector('.zb-edit-msg');
      var fields = {}, changed = 0;

      er.querySelectorAll('[data-field]').forEach(function(el){
        var fm = (el.closest('dd') || el.parentNode).querySelector('.fieldmsg');
        if (fm) { fm.textContent = ''; fm.className = 'fieldmsg'; }
        if (el.value === el.dataset.orig) return;       // unverändert
        fields[el.dataset.field] = el.value;
        changed++;
      });

      // SSH_OPTIONS aus festen Optionen + Schlüssel zusammensetzen.
      var keyInp = er.querySelector('[data-ssh="key"]');
      if (keyInp) {
        var fmk = (keyInp.closest('dd') || keyInp.parentNode).querySelector('.fieldmsg');
        if (fmk) { fmk.textContent = ''; fmk.className = 'fieldmsg'; }
        var composed = sshCompose(keyInp.value);
        if (composed !== sshOrig(er)) {
          fields['SSH_OPTIONS'] = composed;
          changed++;
        }
      }

      if (changed === 0) { msg.className = 'zb-edit-msg'; msg.textContent = 'Keine Änderungen.'; return; }
      msg.className = 'zb-edit-msg'; msg.textContent = 'Speichere …'; btn.disabled = true;

      zbPost(TG_URL, { action: 'edit', id: id }, fields).then(function(r){
        btn.disabled = false;
        if (r.data && r.data.error) {
          msg.className = 'zb-edit-msg err';
          msg.textContent = 'Abgelehnt (HTTP ' + r.status + '): ' + r.data.error;
          return;
        }
        var res = (r.data && r.data.results) || {};
        var okCount = 0, errCount = 0;
        Object.keys(res).forEach(function(f){
          // Fehler am passenden Feld zeigen; SSH_OPTIONS hängt am Schlüssel-Feld.
          var el = er.querySelector('[data-field="' + f + '"]') || (f === 'SSH_OPTIONS' ? keyInp : null);
          var fm = el ? (el.closest('dd') || el.parentNode).querySelector('.fieldmsg') : null;
          if (res[f].ok) { okCount++; if (fm) { fm.className = 'fieldmsg ok'; fm.textContent = 'gespeichert'; } }
          else { errCount++; if (fm) { fm.className = 'fieldmsg err'; fm.textContent = res[f].msg || 'Fehler'; } }
        });
        if (errCount === 0) { location.hash = 'targets'; location.reload(); }
        else { msg.className = 'zb-edit-msg err'; msg.textContent = okCount + ' gespeichert, ' + errCount + ' fehlgeschlagen.'; }
      });
    }

    tgTable.addEventListener('click', function(ev){
      var t = ev.target;

      // Öffnen/Schließen über den Zeilen-Button.
      if (t.classList.contains('zb-edit-btn')) {
        var tr = t.closest('tr[data-id]');
        var er = tr && tr.nextElementSibling;
        if (!er || !er.classList.contains('zb-edit')) return;
        if (er.hasAttribute('hidden')) { sshFill(er); er.removeAttribute('hidden'); t.value = 'Schließen'; }
        else                          { er.setAttribute('hidden', ''); t.value = 'Bearbeiten'; }
        return;
      }
      // Schließen aus dem Editor heraus.
      if (t.classList.contains('zb-edit-close')) {
        var erc = t.closest('tr.zb-edit');
        erc.setAttribute('hidden', '');
        var pr = erc.previousElementSibling;
        var eb = pr && pr.querySelector('.zb-edit-btn');
        if (eb) eb.value = 'Bearbeiten';
        return;
      }
      // Speichern.
      if (t.classList.contains('zb-edit-save')) {
        saveEdit(t.closest('tr.zb-edit'), t);
        return;
      }
    });

    // Aktiv-Schalter -> ENABLED setzen (kein Reload nötig).
    tgTable.addEventListener('change', function(ev){
      if (!ev.target.classList.contains('zb-enabled')) return;
      var tr = ev.target.closest('tr[data-id]');
      var id = tr.dataset.id;
      var val = ev.target.checked ? 'yes' : 'no';
      zbPost(TG_URL, { action:'edit', id:id }, { ENABLED: val }).then(function(r){
        var res = (r.data && r.data.results && r.data.results.ENABLED) || null;
        if (res && res.ok) { rowMsg(tr, true, val === 'yes' ? 'aktiviert' : 'deaktiviert'); }
        else {
          ev.target.checked = !ev.target.checked; // zurückrollen
          rowMsg(tr, false, (res && res.msg) || (r.data && r.data.error) || 'Fehler');
        }
      });
    });
  }

  // ---- Listen-Editor (Array-Felder: Includes/Excludes) -----------------
  // Chips hinzufügen/entfernen; der kanonische (leerzeichengetrennte) Wert
  // steht im versteckten data-name-Feld, das die Speichern-Logik liest.
  function zbListSync(list){
    var hidden = list.querySelector('input[type="hidden"][data-name]');
    var vals = [];
    list.querySelectorAll('.zb-chip-v').forEach(function(s){ vals.push(s.textContent); });
    if (hidden) hidden.value = vals.join(' ');
    var empty = list.querySelector('.zb-list-empty');
    if (empty) empty.style.display = vals.length ? 'none' : '';
  }
  function zbListAdd(list, val){
    val = (val || '').trim();
    if (!val) return;
    var dup = false;
    list.querySelectorAll('.zb-chip-v').forEach(function(s){ if (s.textContent === val) dup = true; });
    if (dup) return;
    var chip = document.createElement('span');
    chip.className = 'zb-chip';
    var v = document.createElement('span');
    v.className = 'zb-chip-v';
    v.textContent = val;
    var x = document.createElement('i');
    x.className = 'fa fa-times zb-chip-x';
    x.setAttribute('role', 'button');
    x.setAttribute('aria-label', 'Entfernen');
    chip.appendChild(v); chip.appendChild(x);
    list.querySelector('.zb-chips').appendChild(chip);
    zbListSync(list);
  }
  document.querySelectorAll('.zb-list').forEach(function(list){
    var input  = list.querySelector('.zb-list-input');
    var addbtn = list.querySelector('.zb-list-addbtn');
    if (addbtn) addbtn.addEventListener('click', function(){ zbListAdd(list, input.value); input.value = ''; input.focus(); });
    if (input)  input.addEventListener('keydown', function(e){
      if (e.key === 'Enter') { e.preventDefault(); zbListAdd(list, input.value); input.value = ''; }
    });
    list.addEventListener('click', function(e){
      var x = e.target.closest('.zb-chip-x');
      if (!x) return;
      var chip = x.closest('.zb-chip');
      if (chip) { chip.parentNode.removeChild(chip); zbListSync(list); }
    });
  });

  // ---- Datei-Browser für den SSH-Schlüssel -----------------------------
  // Nutzt Unraids globale openFileBrowser-Funktion (WebGUI). Den Button nur
  // zeigen, wenn die Funktion existiert; sonst bleibt die manuelle Eingabe.
  if (typeof openFileBrowser === 'function') {
    document.querySelectorAll('.zb-browse').forEach(function(b){ b.hidden = false; });
    document.addEventListener('click', function(ev){
      var b = ev.target.closest && ev.target.closest('.zb-browse');
      if (!b) return;
      var inp = b.parentNode.querySelector('input');
      if (!inp) return;
      // Startverzeichnis: Ordner des aktuellen Werts, sonst /root.
      var root = '/root';
      if (inp.value && inp.value.charAt(0) === '/') {
        root = inp.value.replace(/\/[^\/]*$/, '') || '/';
      }
      try { openFileBrowser(inp, root, '', false, true); } catch (e) { /* Eingabe bleibt manuell möglich */ }
    });
  }
})();
</script>
