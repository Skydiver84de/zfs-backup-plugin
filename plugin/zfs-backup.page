<?php
  /* Konfig-Felder als nativen Unraid-„markdown"-Block aufbauen: pro Option ein
   * Definitionslisten-Eintrag (Name als Term, Eingabefeld als dd) plus – falls
   * vorhanden – die Beschreibung als Blockquote. Unraid macht daraus die native
   * Inline-Hilfe (cursor:help am Namen, Klick klappt die hellblaue Box auf).
   * Der Name steht in Backticks (`code`), damit Markdown Unterstriche in
   * Options-Namen wie WAKE_ON_LAN nicht als Hervorhebung missdeutet. */
  $md = "\n";
  foreach ($groups as $gname => $fields) {
      $md .= '#### ' . $gname . "\n\n";
      foreach ($fields as $f) {
          $name = $f['name'];
          $type = $f['type'];
          $desc = $f['description'];
          $cur  = $values[$name] ?? null;
          // Aktuell keine geheimen Optionen; Maskierung bleibt für künftige Secrets.
          $isSecret = false;

          $md .= '`' . $name . "`:\n";
          $md .= ': ' . zb_cfg_input($name, $type, $cur, $isSecret) . ' <span class="fieldmsg"></span>' . "\n";
          if ($desc !== '' && $desc !== '-') {
              $md .= "\n> " . preg_replace('/\s+/', ' ', $desc) . "\n";
          }
          $md .= "\n";
      }
  }
?>
