<script>
(function(){
  // CSRF-Token: bevorzugt ein serverseitig gerendertes verstecktes Feld
  // (gleiche Quelle wie die Endpoints), sonst die globale WebGUI-Variable.
  function zbCsrf(){
    var el = document.getElementById('zb-csrf') || document.getElementById('zb-csrf-t');
    if (el && el.value) return el.value;
    if (typeof csrf_token !== 'undefined' && csrf_token) return csrf_token;
    return '';
  }

  // POST an einen Plugin-Endpoint; params ist ein Objekt, fields ein optionales
  // Objekt für fields[KEY]=VAL. Liefert ein Promise mit {status, data}.
  function zbPost(url, params, fields){
    var body = 'csrf_token=' + encodeURIComponent(zbCsrf());
    Object.keys(params || {}).forEach(function(k){
      body += '&' + encodeURIComponent(k) + '=' + encodeURIComponent(params[k]);
    });
    Object.keys(fields || {}).forEach(function(k){
      body += '&fields[' + encodeURIComponent(k) + ']=' + encodeURIComponent(fields[k]);
    });
    var status = 0;
    return fetch(url, {
      method:'POST',
      headers:{'Content-Type':'application/x-www-form-urlencoded'},
      body: body
    }).then(function(r){ status = r.status; return r.text(); })
      .then(function(text){
        var data; try { data = JSON.parse(text); }
        catch(e){ data = { error: 'HTTP ' + status + ': ' + text.replace(/\s+/g,' ').slice(0,160) }; }
        return { status: status, data: data };
      });
  }

  // ---- Snapshots-Tab lazy laden (teures --snapshots --json erst bei Bedarf) --
  var snapBody = document.getElementById('zb-snap-body');
  var snapLoaded = false;
  // Standard: Cache vom letzten Lauf (kein zfs, keine Platte geweckt).
  // live=true (Knopf „Aktualisieren") fragt alle Ziele aktiv ab.
  function zbLoadSnapshots(force, live){
    if (!snapBody || (snapLoaded && !force)) return;
    snapLoaded = true;
    snapBody.innerHTML = '<p class="muted">' + (live ? 'Aktualisiere live …' : 'Wird geladen …') + '</p>';
    fetch('/plugins/zfs-backup/include/snapshots.php' + (live ? '?live=1' : ''))
      .then(function(r){ return r.text(); })
      .then(function(html){ snapBody.innerHTML = html; })
      .catch(function(e){ snapBody.innerHTML = '<div class="zb-error">Fehler beim Laden: ' + e + '</div>'; });
  }
  var snapReload = document.getElementById('zb-snap-reload');
  if (snapReload) snapReload.addEventListener('click', function(){ zbLoadSnapshots(true, true); });

  // ---- Aufklappbare Dataset-Zeilen: Snapshots mit vollem Namen + Größe -------
  // (Grundlage fürs spätere gezielte Wiederherstellen.) Klick auf eine
  // Dataset-Zeile lädt einmalig die Snapshots des Datasets (dataset-snapshots.php
  // -> Kern --dataset-snapshots, aus dem State-Cache -> kein Live-zfs, kein
  // Plattenwecken) und klappt sie auf. Delegation überlebt das Fragment-Neuladen.
  function zbBytes(n){
    n = parseFloat(n) || 0;
    var u = ['B','KiB','MiB','GiB','TiB','PiB'], i = 0;
    while (n >= 1024 && i < u.length - 1) { n /= 1024; i++; }
    var d = (i === 0) ? 0 : (n < 10 ? 2 : (n < 100 ? 1 : 0));
    return n.toFixed(d) + ' ' + u[i];
  }
  function zbEsc(s){ return String(s == null ? '' : s).replace(/[&<>"]/g, function(c){
    return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]; }); }
  function zbRenderSnaps(d){
    var s = (d && d.snapshots) || [];
    if (!s.length) return '<p class="muted" style="margin:0">Keine verwalteten Snapshots.</p>';
    var ds = (d && d.dataset) || '', scope = (d && d.scope) || 'source';
    // Nach Typ gruppieren (Stündlich -> Täglich -> ... -> Jährlich), Unbekanntes
    // als "Sonstige" ans Ende. Die Eingangsliste ist bereits nach Datum absteigend
    // sortiert -> innerhalb jeder Gruppe bleibt neueste zuerst.
    var ORDER = ['Hourly','Daily','Weekly','Monthly','Yearly','Snapshot'];
    var LABEL = { Hourly:'Stündlich', Daily:'Täglich', Weekly:'Wöchentlich',
                  Monthly:'Monatlich', Yearly:'Jährlich', Snapshot:'Sonstige' };
    var groups = {};
    s.forEach(function(x){
      var t = LABEL[x.type] ? x.type : 'Snapshot';
      (groups[t] = groups[t] || []).push(x);
    });
    var h = '<table class="zb-snaptbl"><thead><tr><th>Snapshot</th><th>Typ</th>'
          + '<th class="num" title="Referenzierte Datenmenge – das, was beim Wiederherstellen herauskommt">Größe</th>'
          + '<th class="num" title="Exklusiv belegter Platz – wird beim Löschen dieses Snapshots frei">Belegt</th>'
          + '<th>Erstellt</th><th></th></tr></thead><tbody>';
    ORDER.forEach(function(t){
      var g = groups[t];
      if (!g || !g.length) return;
      h += '<tr class="zb-snapgrp"><td colspan="6">' + zbEsc(LABEL[t]) + ' (' + g.length + ')</td></tr>';
      g.forEach(function(x){
        h += '<tr><td class="mono">' + zbEsc(x.snapshot) + '</td><td>' + zbEsc(x.type)
           + '</td><td class="num">' + zbBytes(x.size) + '</td><td class="num">' + zbBytes(x.used)
           + '</td><td>' + zbEsc(x.created) + '</td>'
           + '<td class="num"><button type="button" class="zb-fb-open" data-ds="' + zbEsc(ds)
           + '" data-scope="' + zbEsc(scope) + '" data-snap="' + zbEsc(x.snapshot)
           + '" title="Inhalt dieses Snapshots durchsuchen (greift auf die Platte zu)">Durchsuchen</button></td></tr>';
      });
    });
    return h + '</tbody></table>';
  }
  if (snapBody) {
    snapBody.addEventListener('click', function(ev){
      // Scope-Kopf (Quelle/Ziel) auf-/zuklappen – die Dataset-Tabelle steckt
      // im zb-scope-body und ist schon serverseitig gerendert (nur Zählungen).
      var head = ev.target.closest('.zb-scope-head');
      if (head && snapBody.contains(head)) {
        var scope = head.parentNode;
        var body  = head.nextElementSibling;
        if (body && body.classList.contains('zb-scope-body')) {
          var hidden = (body.style.display === 'none');
          body.style.display = hidden ? 'block' : 'none';
          scope.classList.toggle('open', hidden);
        }
        return;
      }
      // Dataset-Zeile: Einzel-Snapshots lazy nachladen (scope-spezifischer Cache).
      var row = ev.target.closest('.zb-ds-row');
      if (!row || !snapBody.contains(row)) return;
      var detail = row.nextElementSibling;
      if (!detail || !detail.classList.contains('zb-ds-detail')) return;
      if (detail.style.display !== 'none') {           // offen -> zuklappen
        detail.style.display = 'none'; row.classList.remove('open'); return;
      }
      detail.style.display = 'table-row';
      row.classList.add('open');
      if (detail.dataset.loaded !== '1') {
        var cell = detail.querySelector('td');
        cell.innerHTML = '<p class="muted" style="margin:0">Lade Snapshots …</p>';
        fetch('/plugins/zfs-backup/include/dataset-snapshots.php?ds=' + encodeURIComponent(row.dataset.ds)
              + '&scope=' + encodeURIComponent(row.dataset.scope || 'source'))
          .then(function(r){ return r.json(); })
          .then(function(d){ detail.dataset.loaded = '1'; cell.innerHTML = zbRenderSnaps(d); })
          .catch(function(e){ cell.innerHTML = '<div class="zb-error">Fehler: ' + e + '</div>'; });
      }
    });
  }

  // ---- Datei-Browser: Inhalt eines Snapshots durchblättern (lazy je Ebene) ----
  // Liest tatsächlich ins Dataset (.zfs/snapshot) – weckt ggf. Platte/Remote.
  // Klick auf „Inhalt …" öffnet das Modal; Ordner navigieren, Datei = Vorschau
  // (Text, ≤256 KB) bzw. Download.
  var FB_BROWSE = '/plugins/zfs-backup/include/snapshot-browse.php';
  var FB_FILE   = '/plugins/zfs-backup/include/snapshot-file.php';
  var fbBox   = document.getElementById('zb-fb');
  var fbTitle = document.getElementById('zb-fb-title');
  var fbCrumb = document.getElementById('zb-fb-crumbs');
  var fbBody  = document.getElementById('zb-fb-body');
  var fb = { scope:'source', ds:'', snap:'', path:'' };

  function fbUrl(base, extra){
    var u = base + '?ds=' + encodeURIComponent(fb.ds)
          + '&snap=' + encodeURIComponent(fb.snap)
          + '&scope=' + encodeURIComponent(fb.scope);
    return u + (extra || '');
  }
  function fbClose(){ if (fbBox) fbBox.style.display = 'none'; }
  // Scope für den Browser-Titel: "(Quelle)" bzw. "auf <Ziel-Label> (#<id>)"
  // (gleiches Label-Format wie der Ziel-Picker bei den verwaisten Datasets).
  function fbScopeTitle(scope){
    if (scope === 'source' || !scope) return '(Quelle)';
    var t = null;
    for (var i = 0; i < ZB_TARGETS.length; i++) {
      if (ZB_TARGETS[i].id === String(scope)) { t = ZB_TARGETS[i]; break; }
    }
    return 'auf ' + (t ? t.label : ('#' + scope)) + ' (#' + (t ? t.id : scope) + ')';
  }
  function fbOpen(scope, ds, snap){
    fb = { scope: scope || 'source', ds: ds || '', snap: snap || '', path: '' };
    if (fbTitle) fbTitle.textContent = snap + '  ' + fbScopeTitle(scope);
    if (fbBox) fbBox.style.display = 'flex';
    fbLoad('');
  }
  function fbRenderCrumbs(){
    if (!fbCrumb) return;
    var parts = fb.path ? fb.path.split('/') : [];
    var html = '<a href="#" data-fb-path="">/ (Wurzel)</a>', acc = '';
    parts.forEach(function(p){
      acc = acc ? acc + '/' + p : p;
      html += ' <span class="zb-fb-sep">›</span> <a href="#" data-fb-path="' + zbEsc(acc) + '">' + zbEsc(p) + '</a>';
    });
    // Aktuelle Ebene komplett zurückholen: an der Wurzel der GANZE Snapshot,
    // sonst der gerade geöffnete Ordner (data-fb-restore mit dem aktuellen Pfad).
    var rlabel = fb.path ? '↩ Diesen Ordner wiederherstellen' : '↩ Ganzen Snapshot wiederherstellen';
    html += ' <a href="#" class="zb-fb-restore" data-fb-restore="' + zbEsc(fb.path)
          + '" style="margin-left:auto" title="In den Restore-Ordner des Quell-Datasets zurückholen">' + rlabel + '</a>';
    fbCrumb.innerHTML = html;
  }
  function fbLoad(path){
    fb.path = path || '';
    fbRenderCrumbs();
    if (fbBody) fbBody.innerHTML = '<p class="muted" style="margin:0">Lade … (greift auf die Platte zu; schläft der Remote, wird er geweckt – das kann bis zu einer Minute dauern)</p>';
    fetch(fbUrl(FB_BROWSE, '&path=' + encodeURIComponent(fb.path)))
      .then(function(r){ return r.json(); })
      .then(function(d){
        if (!d || d.error) { fbBody.innerHTML = '<div class="zb-error">' + zbEsc((d && d.error) || 'Nicht lesbar') + '</div>'; return; }
        fbBody.innerHTML = fbRenderList(d.entries || []);
      })
      .catch(function(e){ fbBody.innerHTML = '<div class="zb-error">Fehler: ' + e + '</div>'; });
  }
  function fbRenderList(entries){
    // Verzeichnisse zuerst, dann Dateien; je alphabetisch.
    entries.sort(function(a,b){
      var ad = (a.type === 'dir') ? 0 : 1, bd = (b.type === 'dir') ? 0 : 1;
      if (ad !== bd) return ad - bd;
      return String(a.name).localeCompare(String(b.name));
    });
    if (!entries.length) return '<p class="muted" style="margin:0">Leeres Verzeichnis.</p>';
    // Restore aus Quelle UND Replikaten (lokal/remote) – landet immer im
    // _restore-Ordner des Quell-Datasets.
    var canRestore = true;
    var h = '<table class="zb-fb-tbl"><tbody>';
    entries.forEach(function(x){
      var isDir = (x.type === 'dir');
      var icon  = isDir ? '📁' : (x.type === 'link' ? '🔗' : '📄');
      var rel   = fb.path ? fb.path + '/' + x.name : x.name;
      var nameCell = isDir
        ? '<a href="#" class="zb-fb-dir" data-fb-path="' + zbEsc(rel) + '">' + zbEsc(x.name) + '</a>'
        : '<a href="#" class="zb-fb-file" data-fb-file="' + zbEsc(rel) + '" data-fb-size="' + (x.size||0) + '">' + zbEsc(x.name) + '</a>';
      var actCell = canRestore
        ? '<td class="zb-fb-act"><a href="#" class="zb-fb-restore" data-fb-restore="' + zbEsc(rel)
          + '" title="In den Restore-Ordner zurückholen">↩ Wiederherstellen</a></td>'
        : '<td></td>';
      h += '<tr><td class="zb-fb-ic">' + icon + '</td><td class="zb-fb-nm">' + nameCell
         + '</td><td class="num">' + (isDir ? '' : zbBytes(x.size)) + '</td>'
         + '<td class="zb-fb-dt">' + zbEsc(x.modified) + '</td>' + actCell + '</tr>';
    });
    return h + '</tbody></table>';
  }
  var FB_PREVIEW_MAX = 256 * 1024;
  function fbShowFile(rel, size){
    var dl = fbUrl(FB_FILE, '&path=' + encodeURIComponent(rel));
    var name = rel.split('/').pop();
    var restoreLink = ' <a href="#" class="zb-fb-restore" data-fb-restore="' + zbEsc(rel) + '">↩ Wiederherstellen</a>';
    var head = '<div class="zb-fb-fhead"><a href="#" class="zb-fb-back" data-fb-path="' + zbEsc(fb.path) + '">‹ Zurück</a>'
             + ' <span class="mono">' + zbEsc(name) + '</span> <span class="muted">' + zbBytes(size) + '</span>'
             + restoreLink
             + ' <a class="zb-fb-dl" href="' + dl + '" download>Herunterladen</a></div>';
    if (size > FB_PREVIEW_MAX) {
      fbBody.innerHTML = head + '<p class="muted">Datei zu groß für die Vorschau – bitte herunterladen.</p>';
      return;
    }
    fbBody.innerHTML = head + '<p class="muted" style="margin:0">Lade Vorschau …</p>';
    fetch(fbUrl(FB_FILE, '&mode=preview&path=' + encodeURIComponent(rel)))
      .then(function(r){ return r.json(); })
      .then(function(d){
        var note = '';
        if (d && d.binary) { fbBody.innerHTML = head + '<p class="muted">Binärdatei – keine Textvorschau. Bitte herunterladen.</p>'; return; }
        if (d && d.truncated) note = '<p class="muted" style="margin:0 0 6px">Gekürzt auf 256 KB …</p>';
        var txt = (d && d.text) || '';
        fbBody.innerHTML = head + note + '<pre class="zb-fb-prev">' + zbEsc(txt) + '</pre>';
      })
      .catch(function(e){ fbBody.innerHTML = head + '<div class="zb-error">Fehler: ' + e + '</div>'; });
  }

  // Datei/Ordner aus dem Snapshot (Quelle ODER Replikat) in den _restore-Ordner
  // des Quell-Datasets zurückholen.
  var FB_RESTORE = '/plugins/zfs-backup/include/snapshot-restore.php';
  function fbRestore(rel){
    var fromRepl = (fb.scope !== 'source');
    // Leerer Pfad = ganzer Snapshot; sonst der einzelne Eintrag/Ordner.
    var what = rel ? '„' + rel.split('/').pop() + '"' : 'der GESAMTE Snapshot';
    if (!confirm(what + ' aus diesem Snapshot wiederherstellen?\n\n'
                 + 'Wird in den _restore-Ordner des Quell-Datasets kopiert '
                 + '(_restore/' + fb.snap + '/) – überschreibt nichts.'
                 + (fromRepl ? '\n\nHinweis: Restore aus einem Replikat – das Quell-Dataset muss dafür existieren.' : ''))) return;

    // Fortschritt direkt IM Datei-Browser (fbBody) anzeigen – kein zweites
    // Fenster. „‹ Zurück" führt über data-fb-path zurück in die aktuelle Ebene.
    var backLink = '<a href="#" class="zb-fb-back" data-fb-path="' + zbEsc(fb.path) + '">‹ Zurück zur Liste</a>';
    fbBody.innerHTML =
        '<div class="zb-fb-fhead">' + backLink + '</div>'
      + '<div class="muted" style="margin:0 0 8px">' + zbEsc(what)
      + ' wird zurückgeholt … (greift auf die Platte zu; schläft der Remote, wird er geweckt).</div>'
      + '<progress id="zb-rest-bar" max="100" value="0" style="width:100%;height:16px"></progress>'
      + '<div id="zb-rest-pct" class="muted" style="margin-top:6px">starte …</div>';
    var bar = function(){ return document.getElementById('zb-rest-bar'); };
    var pct = function(){ return document.getElementById('zb-rest-pct'); };

    var body = 'csrf_token=' + encodeURIComponent(zbCsrf())
             + '&ds=' + encodeURIComponent(fb.ds)
             + '&snap=' + encodeURIComponent(fb.snap)
             + '&scope=' + encodeURIComponent(fb.scope)
             + '&path=' + encodeURIComponent(rel);
    var dest = '', exit = null, msgs = [], buf = '';

    function handleLine(ln){
      var m;
      if ((m = ln.match(/^FORTSCHRITT (-?\d+)(?:\s+(\d+))?/))) {
        var p = parseInt(m[1], 10), b = bar(), e = pct();
        if (p < 0) {                       // unbestimmt: nur kopierte Bytes
          if (b) b.removeAttribute('value');
          if (e) e.textContent = m[2] ? (zbBytes(parseInt(m[2], 10)) + ' kopiert …') : 'läuft …';
        } else {
          if (b) b.value = p;
          if (e) e.textContent = p + ' %';
        }
      } else if ((m = ln.match(/^ZIEL (.+)/))) {
        dest = m[1];
      } else if ((m = ln.match(/^\[Exit-Code: (\d+)\]/))) {
        exit = parseInt(m[1], 10);
      } else if (ln.trim() !== '') {
        msgs.push(ln);                     // FEHLER/Hinweis-Zeilen für den Fehlerfall
      }
    }

    fetch(FB_RESTORE, { method:'POST',
        headers:{'Content-Type':'application/x-www-form-urlencoded'}, body: body })
      .then(function(resp){
        if (!resp.body || !resp.body.getReader) {       // Fallback ohne Streaming
          return resp.text().then(function(t){ t.split('\n').forEach(handleLine); });
        }
        var reader = resp.body.getReader(), dec = new TextDecoder();
        return (function pump(){ return reader.read().then(function(res){
          if (res.done) { if (buf) handleLine(buf); return; }
          buf += dec.decode(res.value, { stream:true });
          var lines = buf.split('\n'); buf = lines.pop();
          lines.forEach(handleLine);
          return pump();
        }); })();
      })
      .then(function(){
        var ok = (exit === 0) && dest !== '';
        if (ok) {
          fbBody.innerHTML = '<div class="zb-fb-fhead">' + backLink + '</div>'
            + '<div style="margin:0 0 6px;color:#1B7A4B;font-weight:600">✓ Wiederhergestellt nach:</div>'
            + '<pre style="margin:0;white-space:pre-wrap">' + zbEsc(dest) + '</pre>';
          snapLoaded = false;             // Bestand kann sich geändert haben
        } else {
          fbBody.innerHTML = '<div class="zb-fb-fhead">' + backLink + '</div>'
            + '<div class="zb-error" style="margin:0 0 6px">Fehler beim Wiederherstellen:</div>'
            + '<pre style="margin:0;white-space:pre-wrap">' + zbEsc(msgs.join('\n') || 'unbekannt') + '</pre>';
        }
      })
      .catch(function(err){
        fbBody.innerHTML = '<div class="zb-fb-fhead">' + backLink + '</div>'
          + '<div class="zb-error">Fehler: ' + zbEsc(String(err)) + '</div>';
      });
  }

  if (fbBox) {
    document.getElementById('zb-fb-close').addEventListener('click', fbClose);
    fbBox.addEventListener('click', function(ev){
      if (ev.target === fbBox) { fbClose(); return; }   // Klick auf Overlay schließt
      var rest = ev.target.closest('[data-fb-restore]');
      if (rest) { ev.preventDefault(); fbRestore(rest.getAttribute('data-fb-restore')); return; }
      var nav = ev.target.closest('[data-fb-path]');
      if (nav) { ev.preventDefault(); fbLoad(nav.getAttribute('data-fb-path')); return; }
      var file = ev.target.closest('[data-fb-file]');
      if (file) { ev.preventDefault(); fbShowFile(file.getAttribute('data-fb-file'), parseInt(file.getAttribute('data-fb-size'), 10) || 0); return; }
    });
  }
  // „Inhalt …"-Knopf in den aufgeklappten Snapshot-Zeilen (Delegation, da lazy).
  if (snapBody) {
    snapBody.addEventListener('click', function(ev){
      var btn = ev.target.closest('.zb-fb-open');
      if (!btn || !snapBody.contains(btn)) return;
      ev.preventDefault();
      fbOpen(btn.getAttribute('data-scope'), btn.getAttribute('data-ds'), btn.getAttribute('data-snap'));
    });
  }

  // ---- Logs-Tab: Startzeilen laden + live folgen (Push/SSE) -------------
  // Erst die letzten N Zeilen (logs.php), dann per SSE jede NEUE Zeile live
  // anhängen (mode=lines, Start 0 -> keine Doppelung mit dem geladenen Tail).
  var logBody   = document.getElementById('zb-log-body');
  var logSel    = document.getElementById('zb-log-n');
  var logFilter = document.getElementById('zb-log-filter');
  var logCount  = document.getElementById('zb-log-count');
  var logES     = null;
  var logLines  = [];     // vollständiger Puffer (Tail + live), Filter nur Sicht
  var logQuery  = '';     // aktueller Filter (lowercase)

  function logAtBottom(){
    return logBody && (logBody.scrollHeight - logBody.scrollTop - logBody.clientHeight) < 8;
  }
  function logMatches(line){ return !logQuery || line.toLowerCase().indexOf(logQuery) !== -1; }
  function logUpdateCount(shown){
    if (!logCount) return;
    logCount.textContent = logQuery ? (shown + ' / ' + logLines.length + ' Zeilen') : '';
  }
  // Komplett aus dem Puffer neu rendern (bei Filteränderung / Neuladen).
  function logRender(){
    if (!logBody) return;
    var atEnd = logAtBottom();
    var shown = logQuery ? logLines.filter(logMatches) : logLines;
    logBody.textContent = shown.join('\n');
    logUpdateCount(shown.length);
    if (atEnd) logBody.scrollTop = logBody.scrollHeight;
  }
  function zbLogsStreamStop(){
    if (logES) { logES.close(); logES = null; }
  }
  function zbLogsStreamStart(){
    if (logES || !logBody || !window.EventSource) return;
    logES = new EventSource('/plugins/zfs-backup/include/log-stream.php?mode=lines');
    logES.addEventListener('line', function(ev){
      var atEnd = logAtBottom();
      logLines.push(ev.data);
      if (logMatches(ev.data)) {                              // nur sichtbare Zeilen anhängen
        logBody.textContent += (logBody.textContent ? '\n' : '') + ev.data;
        if (atEnd) logBody.scrollTop = logBody.scrollHeight;  // nur mitscrollen, wenn schon unten
      }
      if (logQuery) logUpdateCount(logBody.textContent ? logBody.textContent.split('\n').length : 0);
    });
  }
  // Tail (neu) laden, danach live weiterfolgen.
  function zbLogsLoad(){
    if (!logBody) return;
    zbLogsStreamStop();
    logBody.textContent = 'Wird geladen …';
    var n = logSel ? logSel.value : 200;
    fetch('/plugins/zfs-backup/include/logs.php?n=' + encodeURIComponent(n))
      .then(function(r){ return r.text(); })
      .then(function(txt){ logLines = txt.split('\n'); logRender(); logBody.scrollTop = logBody.scrollHeight; zbLogsStreamStart(); })
      .catch(function(e){ logBody.textContent = 'Fehler beim Laden: ' + e; });
  }
  var logReload = document.getElementById('zb-log-reload');
  if (logReload) logReload.addEventListener('click', function(){ zbLogsLoad(); });
  if (logSel)    logSel.addEventListener('change', function(){ zbLogsLoad(); });
  if (logFilter) logFilter.addEventListener('input', function(){
    logQuery = this.value.trim().toLowerCase();
    logRender();
  });

  // ---- Status-Live-Stream (SSE) + „Lauf starten" -----------------------
  // Die Box #zb-prog ist immer im DOM (versteckt, wenn nichts läuft). Bei
  // aktivem Lauf wird der SSE-Status-Stream abonniert – beides Push: `line`
  // (Logzeile, tail-Kanal) und `status` (Phase/Detail, progress-follow-Kanal);
  // „done" => Lauf beendet -> einmal neu laden. run.php blockiert NICHT mehr:
  // nach dem Start wird die Box sofort eingeblendet und der Stream mit
  // expect=starting geöffnet, der auf den Hochlauf wartet.
  var progEl   = document.getElementById('zb-prog');
  var elPhase  = document.getElementById('zb-prog-phase');
  var elPid    = document.getElementById('zb-prog-pid');
  var elMeta   = document.getElementById('zb-prog-meta');
  var elLog    = document.getElementById('zb-prog-log');    // letzte Logzeile (Push)
  var elDetail = document.getElementById('zb-prog-detail'); // Unterschritt/Prozent
  var elSince  = document.getElementById('zb-prog-since');  // „läuft seit …"
  var runBtn   = document.getElementById('zb-run-btn');
  var badgeEl  = document.getElementById('zb-badge');
  var statusES = null;
  var statusActive = false;        // soll der Status-Stream offen sein?

  // Lauf erkannt (über den Watch-Stream): Fortschrittsbox zeigen, „Lauf starten"
  // ausblenden, Badge auf „läuft". Greift auch bei extern (Cron/CLI) gestarteten
  // Läufen, ohne dass der Browser pollt.
  function zbShowRunning(){
    if (progEl) { progEl.dataset.running = '1'; progEl.style.display = ''; }
    if (runBtn) runBtn.style.display = 'none';
    if (badgeEl) { badgeEl.textContent = 'läuft'; badgeEl.className = 'zb-badge run'; }
    var warn = document.querySelector('.zb-warn');   // „veraltet"-Banner während des Laufs ausblenden
    if (warn) warn.style.display = 'none';
  }

  // lastChange = wann sich zuletzt etwas geändert hat (Logzeile ODER Detail).
  // Treibt den „läuft seit"-Ticker, der echten Stillstand sichtbar macht, ohne
  // dass eine lange Einzeloperation wie ein Hänger wirkt.
  var lastChange = Date.now();
  function zbBump(){ lastChange = Date.now(); }
  function zbPad(n){ return (n < 10 ? '0' : '') + n; }
  function zbTick(){
    if (!elSince) return;
    if (!statusActive) { elSince.textContent = ''; return; }
    var s = Math.floor((Date.now() - lastChange) / 1000);
    // Erst ab ein paar Sekunden Stillstand anzeigen – bei aktiver Bewegung leer.
    elSince.textContent = (s >= 4) ? ('· läuft seit ' + Math.floor(s/60) + ':' + zbPad(s%60)) : '';
  }
  setInterval(zbTick, 1000);

  function onStatusTab(){ return location.hash === '' || location.hash === '#status'; }

  function zbStatusStop(){ if (statusES) { statusES.close(); statusES = null; } }

  function zbStatusStart(expectStarting){
    statusActive = true;
    // Im Hintergrund-Tab keinen Worker halten – wird bei Sichtbarkeit reaktiviert.
    if (statusES || !window.EventSource || document.hidden) return;
    lastChange = Date.now();    // Ticker frisch starten (auch nach Tab-Rückkehr)
    var url = '/plugins/zfs-backup/include/log-stream.php?mode=status'
            + (expectStarting ? '&expect=starting' : '');
    statusES = new EventSource(url);
    statusES.addEventListener('line', function(ev){
      // Logzeile kommt sofort (Push, eigener tail-Kanal).
      if (elLog && ev.data !== elLog.textContent) { elLog.textContent = ev.data; zbBump(); }
    });
    statusES.addEventListener('status', function(ev){
      var s; try { s = JSON.parse(ev.data); } catch(e){ return; }
      zbShowRunning();   // ein Status-Event heißt: es läuft gerade
      if (elPhase) elPhase.textContent = s.phase || '';
      if (elPid)   elPid.textContent   = s.pid ? ('(PID ' + s.pid + ')') : '';
      if (elMeta)  elMeta.textContent  = 'gestartet ' + (s.started || '') + ' · aktualisiert ' + (s.updated || '');
      var d = s.detail || '';
      if (elDetail && d !== elDetail.textContent) { elDetail.textContent = d; zbBump(); }
    });
    statusES.addEventListener('done', function(){
      zbStatusStop();
      statusActive = false;
      if (onStatusTab()) location.reload();   // Lauf fertig -> Ergebnis-Karten frisch
    });
    statusES.addEventListener('notrunning', function(){
      // Reconnect (z. B. nach Tab-Rückkehr): kein Lauf aktiv. Zeigten wir noch
      // „läuft", ist er in der Zwischenzeit fertig geworden -> neu laden. Sonst
      // (leerlaufende Statusseite) ignorieren und auf den nächsten Lauf warten.
      if (progEl && progEl.dataset.running === '1' && onStatusTab()) location.reload();
    });
  }

  // Der Status-Watch wird über activate(tabFromHash()) weiter unten gestartet
  // (sobald der Status-Tab aktiv ist) – er erkennt einen laufenden ODER einen
  // gleich startenden Lauf. Kein Sonderfall fürs Laden nötig.

  if (runBtn) {
    runBtn.addEventListener('click', function(){
      var msg = document.getElementById('zb-run-msg');
      if (!confirm('Jetzt einen Backup-Lauf starten?')) return;
      runBtn.disabled = true;
      if (msg) { msg.className = 'zb-savemsg'; msg.textContent = 'Wird gestartet …'; }
      zbPost('/plugins/zfs-backup/include/run.php', {}).then(function(r){
        if (r.data && r.data.ok) {
          if (msg) msg.textContent = '';
          runBtn.style.display = 'none';
          if (progEl) {
            progEl.style.display = '';
            if (elPhase) elPhase.textContent = 'startet …';
            if (elMeta)  elMeta.textContent  = '';
            if (elPid)   elPid.textContent   = '';
            if (elLog)    elLog.textContent    = 'Lauf wird gestartet …';
            if (elDetail) elDetail.textContent = '';
          }
          lastChange = Date.now();
          zbStatusStart(true);                  // wartet auf den Hochlauf
        } else {
          runBtn.disabled = false;
          if (msg) { msg.className = 'zb-savemsg err';
            msg.textContent = (r.data && (r.data.msg || r.data.error)) || 'Start fehlgeschlagen.'; }
        }
      });
    });
  }

  // „Simulieren" (Dry-Run): zeigt, was ein Lauf täte, ohne etwas zu ändern.
  // Streamt --simulate (read-only) ins Modal – gleiches Muster wie Wartung/Test.
  var simBtn = document.getElementById('zb-sim-btn');
  if (simBtn) {
    simBtn.addEventListener('click', function(){
      simBtn.disabled = true;
      var body = 'csrf_token=' + encodeURIComponent(zbCsrf()) + '&action=simulate';
      zbStream('/plugins/zfs-backup/include/maintenance.php', body,
               'Simulation (Dry-Run)', 'Simuliere …\n\n').then(function(text){
        simBtn.disabled = false;
        zbModalStatus(/\[Exit-Code: 0\]/.test(text));
      }).catch(function(e){
        simBtn.disabled = false;
        zbModalBody('Fehler: ' + e);
        zbModalStatus(false);
      });
    });
  }

  // ---- Zeitplan-Tab (Cron) ---------------------------------------------
  var SCHED_URL  = '/plugins/zfs-backup/include/schedule.php';
  var schEnabled = document.getElementById('sch-enabled');
  var schFreq    = document.getElementById('sch-freq');
  var schHour    = document.getElementById('sch-hour');
  var schMinute  = document.getElementById('sch-minute');
  var schDow     = document.getElementById('sch-dow');
  var schMin     = document.getElementById('sch-min');
  var schCron    = document.getElementById('sch-cron');
  var schState   = document.getElementById('zb-sch-state');
  var schSave    = document.getElementById('zb-sch-save');
  var schMsg     = document.getElementById('zb-sch-msg');
  var schLoaded  = false;

  function schIsNum(s){ return /^\d+$/.test(s); }

  // Aus den Preset-Feldern den Cron-Ausdruck berechnen (custom: Feld bleibt frei).
  function schComputeCron(){
    if (!schFreq || schFreq.value === 'custom') return;
    var hh = schHour   ? (parseInt(schHour.value, 10)   || 0) : 0;
    var mm = schMinute ? (parseInt(schMinute.value, 10) || 0) : 0;
    var expr = '';
    if (schFreq.value === 'hourly')      expr = (parseInt(schMin.value, 10) || 0) + ' * * * *';
    else if (schFreq.value === 'daily')  expr = mm + ' ' + hh + ' * * *';
    else if (schFreq.value === 'weekly') expr = mm + ' ' + hh + ' * * ' + (schDow ? schDow.value : '1');
    if (schCron) schCron.value = expr;
  }
  // Felder je nach Häufigkeit aktivieren + Cron read-only/editierbar.
  function schSyncFields(){
    if (!schFreq) return;
    var f = schFreq.value;
    var useTime = (f === 'daily' || f === 'weekly');
    if (schHour)   schHour.disabled   = !useTime;
    if (schMinute) schMinute.disabled = !useTime;
    if (schDow)    schDow.disabled    = (f !== 'weekly');
    if (schMin)    schMin.disabled    = (f !== 'hourly');
    if (schCron)   schCron.readOnly   = (f !== 'custom');
    schComputeCron();
  }
  // Gespeicherten Cron-Ausdruck in die Preset-Felder zurücklesen.
  function schSetTime(h, m){
    if (schHour)   schHour.value   = String(parseInt(h, 10) || 0);
    if (schMinute) schMinute.value = String(parseInt(m, 10) || 0);
  }
  function schParseCron(expr){
    var p = (expr || '').trim().split(/\s+/);
    if (p.length !== 5) { schFreq.value = 'custom'; schCron.value = expr || ''; return; }
    var m = p[0], h = p[1], dom = p[2], mon = p[3], dow = p[4];
    if (dom === '*' && mon === '*' && dow === '*' && h === '*' && schIsNum(m)) {
      schFreq.value = 'hourly'; schMin.value = String(parseInt(m, 10) || 0);
    } else if (dom === '*' && mon === '*' && dow === '*' && schIsNum(h) && schIsNum(m)) {
      schFreq.value = 'daily';  schSetTime(h, m);
    } else if (dom === '*' && mon === '*' && schIsNum(dow) && schIsNum(h) && schIsNum(m)) {
      schFreq.value = 'weekly'; schSetTime(h, m); schDow.value = dow;
    } else {
      schFreq.value = 'custom'; schCron.value = expr;
    }
  }
  function schRenderState(d){
    if (!schState) return;
    schState.textContent = (d && d.enabled && d.cron)
      ? 'Aktiv – geplant nach Cron „' + d.cron + '".'
      : 'Kein Zeitplan aktiv – Läufe nur manuell oder extern.';
  }
  function zbSchedLoad(){
    if (schLoaded || !schFreq) return;
    schLoaded = true;
    fetch(SCHED_URL, {headers:{'Accept':'application/json'}})
      .then(function(r){ return r.json(); })
      .then(function(d){
        schEnabled.value = (d && d.enabled) ? 'yes' : 'no';
        schParseCron(d && d.cron ? d.cron : '0 2 * * *');
        schSyncFields();
        schRenderState(d);
      })
      .catch(function(){ schLoaded = false;
        if (schState) schState.textContent = 'Zeitplan konnte nicht geladen werden.'; });
  }
  if (schFreq) {
    schFreq.addEventListener('change', schSyncFields);
    if (schHour)   schHour.addEventListener('change',   schComputeCron);
    if (schMinute) schMinute.addEventListener('change', schComputeCron);
    if (schDow)    schDow.addEventListener('change',    schComputeCron);
    if (schMin)    schMin.addEventListener('change',    schComputeCron);
  }
  if (schSave) {
    schSave.addEventListener('click', function(){
      schComputeCron();
      var enabled = (schEnabled && schEnabled.value === 'yes') ? 'yes' : 'no';
      var cron    = ((schCron && schCron.value) || '').trim();
      schMsg.className = 'zb-savemsg'; schMsg.textContent = 'Speichere …';
      schSave.disabled = true;
      var body = 'csrf_token=' + encodeURIComponent(zbCsrf()) +
                 '&enabled=' + encodeURIComponent(enabled) +
                 '&cron=' + encodeURIComponent(cron);
      fetch(SCHED_URL, {method:'POST',
        headers:{'Content-Type':'application/x-www-form-urlencoded'}, body: body})
        .then(function(r){ return r.text(); })
        .then(function(text){
          schSave.disabled = false;
          var d; try { d = JSON.parse(text); }
          catch(e){ schMsg.className='zb-savemsg err'; schMsg.textContent='Unerwartete Antwort.'; return; }
          if (d.ok) {
            schMsg.className='zb-savemsg'; schMsg.textContent='Gespeichert.';
            schLoaded = false; zbSchedLoad();
          } else {
            schMsg.className='zb-savemsg err'; schMsg.textContent = d.msg || 'Fehler beim Speichern.';
          }
        })
        .catch(function(e){ schSave.disabled=false;
          schMsg.className='zb-savemsg err'; schMsg.textContent='Fehler: ' + e; });
    });
  }

  // Im Hintergrund-Tab keine SSE-Verbindung offen halten (spart php-fpm-Worker,
  // gerade bei mehreren Tabs/Geräten); bei Rückkehr wieder aufnehmen.
  document.addEventListener('visibilitychange', function(){
    if (document.hidden) {
      zbStatusStop();
      zbLogsStreamStop();
    } else {
      if (statusActive) zbStatusStart(false);
      var lp = document.querySelector('.zb-panel[data-panel="logs"]');
      if (lp && lp.classList.contains('active')) zbLogsLoad();
    }
  });

  // ---- Tabs -------------------------------------------------------------
  var tabs   = document.querySelectorAll('.zb-tab');
  var panels = document.querySelectorAll('.zb-panel');
  function activate(name){
    tabs.forEach(function(t){ t.classList.toggle('active', t.dataset.tab === name); });
    panels.forEach(function(p){ p.classList.toggle('active', p.dataset.panel === name); });
    if (name === 'snapshots') zbLoadSnapshots(false);
    if (name === 'schedule')  zbSchedLoad();
    // Status-Watch nur auf dem Status-Tab offen halten (erkennt auch extern
    // gestartete Läufe); beim Verlassen schließen, um keinen Worker zu binden.
    if (name === 'status') { zbStatusStart(false); }
    else { zbStatusStop(); statusActive = false; }
    // Logs nur folgen, solange der Tab offen ist – beim Verlassen Stream schließen.
    if (name === 'logs') { zbLogsLoad(); } else { zbLogsStreamStop(); }
  }
  tabs.forEach(function(t){
    t.addEventListener('click', function(){
      location.hash = (t.dataset.tab === 'status') ? '' : t.dataset.tab;
      activate(t.dataset.tab);
    });
  });
  function tabFromHash(){
    var h = location.hash.replace('#','');
    return ['config','targets','snapshots','schedule','wartung','logs'].indexOf(h) >= 0 ? h : 'status';
  }
  activate(tabFromHash());
  // Hash-Wechsel (z. B. Link „#snapshots" aus dem Status-Tab, Browser-Zurück).
  window.addEventListener('hashchange', function(){ activate(tabFromHash()); });

  // ---- Konfiguration speichern -----------------------------------------
  // Falls das gerenderte Markdown ein <form> enthält: Enter soll die Seite
  // nicht neu laden (Speichern läuft per AJAX).
  var cfgForm = document.querySelector('#zb-config-form form');
  if (cfgForm) cfgForm.addEventListener('submit', function(e){ e.preventDefault(); });

  var saveBtn = document.getElementById('zb-save-btn');
  if (saveBtn) {
    saveBtn.addEventListener('click', function(){
      var inputs = document.querySelectorAll('#zb-config-form [data-name]');
      var fields = {};
      var changed = 0;

      inputs.forEach(function(el){
        // Feldmeldung zurücksetzen: das Feld sitzt im markdown-dd, die .fieldmsg
        // im selben dd (beim Array-Feld liegt das Hidden-Input zusätzlich in .zb-list).
        var fm = (el.closest('dd') || el.parentNode).querySelector('.fieldmsg');
        if (fm) { fm.textContent=''; fm.className='fieldmsg'; }

        var val  = el.value;
        var orig = el.dataset.orig;
        if (el.dataset.type === 'secret') {
          // Secrets nur senden, wenn etwas eingegeben wurde.
          if (val === '') return;
        } else {
          if (val === orig) return;            // unverändert -> nicht senden
          if (el.dataset.type === 'array' && val.trim() === '') {
            val = '-';                          // leeres Array -> Skript-Konvention
          }
        }
        fields[el.dataset.name] = val;
        changed++;
      });

      var msg = document.getElementById('zb-save-msg');
      if (changed === 0) { msg.className='zb-savemsg'; msg.textContent='Keine Änderungen.'; return; }

      msg.className='zb-savemsg'; msg.textContent='Speichere …';
      saveBtn.disabled = true;

      var body = 'csrf_token=' + encodeURIComponent(zbCsrf());
      Object.keys(fields).forEach(function(k){
        body += '&fields[' + encodeURIComponent(k) + ']=' + encodeURIComponent(fields[k]);
      });

      var httpStatus = 0;
      fetch('/plugins/zfs-backup/include/save.php', {
        method:'POST',
        headers:{'Content-Type':'application/x-www-form-urlencoded'},
        body: body
      })
      .then(function(r){ httpStatus = r.status; return r.text(); })
      .then(function(text){
        saveBtn.disabled = false;
        var data;
        try { data = JSON.parse(text); }
        catch (e) {
          // Keine JSON-Antwort -> Status + Auszug zeigen (z. B. 403/404/Login-HTML).
          msg.className='zb-savemsg err';
          msg.textContent = 'Unerwartete Antwort (HTTP ' + httpStatus + '): ' +
                            text.replace(/\s+/g,' ').slice(0,160);
          return;
        }
        if (data && data.error) {
          msg.className='zb-savemsg err';
          msg.textContent = 'Abgelehnt (HTTP ' + httpStatus + '): ' + data.error;
          return;
        }
        var res = (data && data.results) || {};
        var okCount = 0, errCount = 0;
        Object.keys(res).forEach(function(name){
          var el = document.querySelector('#zb-config-form [data-name="'+name+'"]');
          var fm = el ? (el.closest('dd') || el.parentNode).querySelector('.fieldmsg') : null;
          if (res[name].ok) {
            okCount++;
            if (el && el.dataset.type !== 'secret') el.dataset.orig = el.value;
            if (fm) { fm.className='fieldmsg ok'; fm.textContent='gespeichert'; }
          } else {
            errCount++;
            if (fm) { fm.className='fieldmsg err'; fm.textContent = res[name].msg || 'Fehler'; }
          }
        });
        if (errCount === 0) { msg.className='zb-savemsg ok';  msg.textContent = okCount + ' gespeichert.'; }
        else                { msg.className='zb-savemsg err'; msg.textContent = okCount + ' gespeichert, ' + errCount + ' fehlgeschlagen.'; }
      })
      .catch(function(e){
        saveBtn.disabled = false;
        msg.className='zb-savemsg err'; msg.textContent = 'Fehler beim Speichern: ' + e;
      });
    });
  }

  // ---- Ziele -----------------------------------------------------------
  var TG_URL = '/plugins/zfs-backup/include/targets.php';

  function rowMsg(tr, ok, text){
    var m = tr.querySelector('.rowmsg');
    if (!m) return;
    m.className = 'rowmsg ' + (ok ? 'ok' : 'err');
    m.textContent = text;
  }

  // SSH-Optionen sind fix; einstellbar ist nur die Schlüsseldatei. IdentitiesOnly
  // gehört zur festen Basis (eine ZFS-Replikation läuft ohnehin per Key-Auth, und
  // IdentitiesOnly ergibt nur mit gesetztem -i Sinn). sshKeyOf zieht den vorhandenen
  // -i-Pfad aus SSH_OPTIONS (zum Vorbefüllen), sshCompose hängt nur noch den
  // Schlüssel an.
  var SSH_FIXED = '-o BatchMode=yes -o ConnectTimeout=10 -o UpdateHostKeys=no -o IdentitiesOnly=yes';
  function sshKeyOf(opts){
    var toks = (opts || '').trim().split(/\s+/);
    for (var i = 0; i < toks.length; i++){
      if (toks[i] === '-i' && i + 1 < toks.length) return toks[i + 1];
    }
    return '';
  }
  function sshCompose(key){
    key = (key || '').trim();
    return key ? SSH_FIXED + ' -i ' + key : SSH_FIXED;
  }
  // Originalwert gleich normalisieren, damit reines Öffnen+Speichern ohne echte
  // Änderung NICHT als Änderung zählt.
  function sshOrig(er){
    return sshCompose(sshKeyOf(er.getAttribute('data-orig-ssh') || ''));
  }

  // Popup mit Live-Ausgabe.
  var modal     = document.getElementById('zb-modal');
  var modalBody = document.getElementById('zb-modal-body');
  function zbModalOpen(title){
    if (!modal) return;
    document.getElementById('zb-modal-title').textContent = title;
    modal.querySelector('.zb-modal-head').className = 'zb-modal-head';
    modalBody.textContent = '';
    modal.style.display = 'flex';
  }
  function zbModalBody(text){
    if (!modalBody) return;
    modalBody.textContent = text;
    modalBody.scrollTop = modalBody.scrollHeight;   // mitlaufen
  }
  function zbModalStatus(ok){
    if (modal) modal.querySelector('.zb-modal-head').className = 'zb-modal-head ' + (ok ? 'ok' : 'err');
  }
  // Nach manchen Aktionen (z. B. Orphan-Löschen) muss die serverseitig
  // gerenderte Statusseite frisch geladen werden – das machen wir beim Schließen
  // des Ergebnis-Modals, damit der Nutzer die Ausgabe vorher noch lesen kann.
  var zbReloadOnClose = false;
  function zbModalDismiss(){
    if (!modal) return;
    modal.style.display = 'none';
    if (zbReloadOnClose) { zbReloadOnClose = false; location.reload(); }
  }
  if (modal) {
    document.getElementById('zb-modal-close').addEventListener('click', zbModalDismiss);
    modal.addEventListener('click', function(e){ if (e.target === modal) zbModalDismiss(); });
    document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && modal.style.display !== 'none') zbModalDismiss(); });
  }

  // POST an einen Endpoint und Live-Ausgabe ins Modal streamen. Liefert ein
  // Promise mit dem gesamten Text (letzte Zeile trägt „[Exit-Code: N]").
  function zbStream(url, body, title, startMsg){
    zbModalOpen(title);
    zbModalBody(startMsg || '');
    return fetch(url, {
      method:'POST',
      headers:{'Content-Type':'application/x-www-form-urlencoded'},
      body: body
    }).then(function(resp){
      // Live mitlesen, sofern der Browser Streams unterstützt; sonst auf
      // einmaliges Lesen am Ende zurückfallen.
      if (!resp.body || !resp.body.getReader) {
        return resp.text().then(function(t){ zbModalBody(t); return t; });
      }
      var reader = resp.body.getReader();
      var dec = new TextDecoder();
      var buf = '';
      return (function pump(){
        return reader.read().then(function(res){
          if (res.done) return buf;
          buf += dec.decode(res.value, { stream:true });
          zbModalBody(buf);
          return pump();
        });
      })();
    });
  }

  // ---- Wartung-Tab: Prüfen/Wartung -------------------------------------
  var MT_URL = '/plugins/zfs-backup/include/maintenance.php';
  var maintPanel = document.querySelector('[data-panel="wartung"]');

  // Auswahl-Popup für die Ziel-Wahl (Verwaiste-Datasets-Aktionen).
  var ZB_TARGETS = <?= json_encode(array_map(function($t){ return ['id' => (string)($t['id'] ?? ''), 'label' => (string)($t['label'] ?? ($t['id'] ?? '')) ]; }, is_array($targets) ? $targets : [])) ?>;
  var pickBox   = document.getElementById('zb-pick');
  var pickBody  = document.getElementById('zb-pick-body');
  var pickTitle = document.getElementById('zb-pick-title');
  function zbPickClose(){ if (pickBox) pickBox.style.display = 'none'; }
  // Generischer Auswahl-Dialog: opts = [{label, value}]; cb(opts[i]).
  var ZB_PICK_OPTS = [];
  function zbPick(title, hint, opts, cb){
    if (!pickBox) { if (opts.length) cb(opts[0]); return; }   // Fallback: erste Option
    ZB_PICK_OPTS = opts;
    pickTitle.textContent = title;
    var h = hint ? '<p class="zb-pick-hint">' + zbEsc(hint) + '</p>' : '';
    opts.forEach(function(o, i){
      h += '<button type="button" class="zb-pick-opt" data-i="' + i + '">'
         + zbEsc(o.label) + '</button>';
    });
    pickBody.innerHTML = h;
    pickBox.style.display = 'flex';
    pickBody.onclick = function(ev){
      var b = ev.target.closest('.zb-pick-opt');
      if (!b) return;
      zbPickClose();
      cb(ZB_PICK_OPTS[parseInt(b.getAttribute('data-i'), 10)]);
    };
  }
  // Ziel-Auswahl für Orphan-Aktionen (leerer value = alle Ziele).
  function zbOrphanPick(title, cb){
    var opts = [{ label: 'Alle Ziele', value: '' }];
    ZB_TARGETS.forEach(function(t){
      opts.push({ label: t.label + ' (#' + t.id + ')', value: t.id });
    });
    zbPick(title, 'Für welches Ziel?', opts, function(o){ cb(o.value); });
  }
  if (pickBox) {
    document.getElementById('zb-pick-close').addEventListener('click', zbPickClose);
    pickBox.addEventListener('click', function(ev){ if (ev.target === pickBox) zbPickClose(); });
  }

  // Führt eine Wartungsaktion aus (mit ggf. Bestätigung/Tipp-Phrase). target =
  // optionale Ziel-ID (nur Orphan-Aktionen; leer = alle Ziele).
  function zbMaintExecute(btn, target, actOverride, titleOverride){
    var act = actOverride || btn.dataset.act;
    var title = titleOverride || btn.dataset.title || act;
    if (btn.dataset.confirm && !confirm(btn.dataset.confirm)) return;
    if (btn.dataset.phrase) {
      var typed = prompt('Zur Bestätigung bitte „' + btn.dataset.phrase + '" eintippen:');
      if (typed === null) return;
      if (typed.trim() !== btn.dataset.phrase) {
        zbModalOpen(title);
        zbModalBody('Abgebrochen: Bestätigungstext stimmt nicht.');
        zbModalStatus(false);
        return;
      }
    }
    btn.disabled = true;
    var body = 'csrf_token=' + encodeURIComponent(zbCsrf()) +
               '&action=' + encodeURIComponent(act);
    if (target) body += '&target=' + encodeURIComponent(target);
    zbStream(MT_URL, body, title, 'Läuft …\n\n').then(function(text){
      btn.disabled = false;
      var ok = /\[Exit-Code: 0\]/.test(text);
      zbModalStatus(ok);
      // Aktionen, die den Bestand verändern: Snapshots-Tab neu laden.
      if (ok && (act === 'thin-history' || act === 'delete-managed-snapshots' || act === 'cleanup-orphans')) {
        snapLoaded = false;
      }
      // Orphan-Löschen ändert den Status-Zähler: Seite beim Schließen neu laden.
      if (ok && act === 'cleanup-orphans') { zbReloadOnClose = true; }
    }).catch(function(e){
      btn.disabled = false;
      zbModalBody('Fehler: ' + e);
      zbModalStatus(false);
    });
  }

  if (maintPanel) {
    maintPanel.addEventListener('click', function(ev){
      var btn = ev.target.closest('.zb-act');
      if (!btn) return;
      var act = btn.dataset.act;
      // Snapshots prüfen: erst Umfang im Popup wählen (alles / Quelle / je Ziel).
      if (act === 'verify-pick') {
        var vopts = [
          { label: 'Alles (Quelle + alle Ziele)', act: 'verify',        target: '', title: 'Prüfen: alles' },
          { label: 'Nur Quelle',                   act: 'verify-source', target: '', title: 'Prüfen: Quelle' }
        ];
        ZB_TARGETS.forEach(function(t){
          vopts.push({ label: t.label + ' (#' + t.id + ')', act: 'verify-target',
                       target: t.id, title: 'Prüfen: ' + t.label });
        });
        zbPick('Snapshots prüfen – Umfang wählen', 'Was soll geprüft werden?', vopts,
               function(o){ zbMaintExecute(btn, o.target, o.act, o.title); });
        return;
      }
      // Orphan-Aktionen: erst Ziel im Popup wählen, dann ausführen.
      if (act === 'cleanup-orphans' || act === 'cleanup-orphans-dry') {
        var del = (act === 'cleanup-orphans');
        zbOrphanPick(del ? 'Verwaiste Datasets löschen – Ziel wählen'
                         : 'Verwaiste Datasets anzeigen – Ziel wählen',
                     function(target){ zbMaintExecute(btn, target); });
        return;
      }
      zbMaintExecute(btn, null);
    });
  }

  // „Ziel hinzufügen": Host-Zeile nur bei Remote zeigen.
