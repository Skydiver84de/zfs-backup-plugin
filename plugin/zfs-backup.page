<?php
/*
 * zfs-backup – Unraid-Plugin-GUI (Tabs: Status, Konfiguration, Ziele,
 * Snapshots, Wartung, Logs, Zeitplan).
 *
 * Formularfelder werden über Unraids Markdown-Konverter gerendert (native
 * Inline-Hilfe), siehe zb_md().
 *
 * Diese Seite enthält KEINE ZFS-/Backup-Logik. Sie ruft ausschließlich die
 * headless-Schnittstelle des Skripts über den Wrapper auf und stellt das JSON
 * dar bzw. reicht Eingaben über die bestehende Validierung weiter (die GUI ist
 * nur eine Sicht auf den Kern).
 */

$ZB_CLI = '/usr/local/sbin/zfs-backup';

/* Ruft den Wrapper mit den übergebenen Argumenten und dekodiert die JSON-Ausgabe.
 * Gibt [data|null, rc] zurück. */
function zb_json(string $args): array {
    global $ZB_CLI;
    $out = [];
    $rc  = 0;
    exec(escapeshellarg($ZB_CLI) . ' ' . $args . ' 2>/dev/null', $out, $rc);
    $data = json_decode(implode("\n", $out), true);
    return [$data, $rc];
}

/* HTML-sichere Ausgabe, mit Fallback. */
function zb_h($v, string $fallback = '–'): string {
    if ($v === null || $v === '' || $v === '-') return $fallback;
    return htmlspecialchars((string)$v, ENT_QUOTES, 'UTF-8');
}

/* Bytes menschenlesbar (binär, wie zfs). */
function zb_bytes($n): string {
    $n = (float)$n;
    $u = ['B','KiB','MiB','GiB','TiB','PiB'];
    $i = 0;
    while ($n >= 1024 && $i < count($u) - 1) { $n /= 1024; $i++; }
    $d = ($i === 0) ? 0 : ($n < 10 ? 2 : ($n < 100 ? 1 : 0));
    return number_format($n, $d) . ' ' . $u[$i];
}

/* Attribut-sichere Ausgabe (kein Fallback). */
function zb_a($v): string {
    return htmlspecialchars((string)$v, ENT_QUOTES, 'UTF-8');
}

/* --- Eingabefelder ------------------------------------------------------
 * Liefern reines Markup als EINZEILIGE HTML-Zeichenkette (wichtig, da sie als
 * dd-Inhalt ins native Unraid-„markdown" eingesetzt werden). data-orig trägt den
 * Ausgangswert für den Änderungsvergleich beim Speichern. KEINE Logik – nur
 * Darstellung der vom Kern gelieferten Werte.
 *
 * $attr unterscheidet die beiden Speicherwege: 'data-name' (Konfig-Tab ->
 * save.php) bzw. 'data-field' (Ziel-Editor -> targets.php). */
function zb_input(string $attr, string $name, string $type, string $val, string $ph = ''): string {
    $a = $attr . '="' . zb_a($name) . '"';
    if ($type === 'bool') {
        $on = ($val === 'yes');
        return '<select ' . $a . ' data-type="bool" data-orig="' . ($on ? 'yes' : 'no') . '">'
             . '<option value="yes"' . ($on ? ' selected' : '') . '>ja</option>'
             . '<option value="no"'  . ($on ? '' : ' selected') . '>nein</option></select>';
    }
    if ($type === 'number') {
        $v = (string)(int)$val;
        return '<input type="number" min="0" step="1" ' . $a . ' data-type="number" data-orig="' . zb_a($v) . '" value="' . zb_a($v) . '">';
    }
    return '<input type="text" ' . $a . ' data-type="string" data-orig="' . zb_a($val) . '" value="' . zb_a($val) . '"'
         . ($ph !== '' ? ' placeholder="' . zb_a($ph) . '"' : '') . '>';
}

/* Dünne Wrapper für den Ziel-Editor (data-field). */
function zb_ed_text(string $field, $val, string $ph = ''): string {
    return zb_input('data-field', $field, 'string', (string)($val ?? ''), $ph);
}
function zb_ed_num(string $field, $val): string {
    return zb_input('data-field', $field, 'number', (string)(int)($val ?? 0));
}
function zb_ed_bool(string $field, $on): string {
    return zb_input('data-field', $field, 'bool', $on ? 'yes' : 'no');
}

/* Eingabefeld für eine Konfig-Option (data-name). array/secret sind Konfig-
 * spezifisch, der Rest läuft über zb_input(). */
function zb_cfg_input(string $name, string $type, $cur, bool $isSecret): string {
    if ($type === 'bool') {
        return zb_input('data-name', $name, 'bool', ($cur === 'yes' || $cur === true) ? 'yes' : 'no');
    }
    /* enum:opt1,opt2,... -> Dropdown mit fester Auswahl (wie bool, data-type=string). */
    if (strncmp($type, 'enum:', 5) === 0) {
        $opts = explode(',', substr($type, 5));
        $val  = (string)($cur ?? '');
        $h = '<select data-name="' . zb_a($name) . '" data-type="string" data-orig="' . zb_a($val) . '">';
        foreach ($opts as $o) {
            $sel = ($o === $val) ? ' selected' : '';
            $h .= '<option value="' . zb_a($o) . '"' . $sel . '>' . zb_h($o) . '</option>';
        }
        return $h . '</select>';
    }
    if ($type === 'number') {
        return zb_input('data-name', $name, 'number', (string)(int)($cur ?? 0));
    }
    if ($type === 'array') {
        $items  = is_array($cur) ? $cur : [];
        $joined = implode(' ', $items);
        $chips  = '';
        foreach ($items as $it) {
            $chips .= '<span class="zb-chip"><span class="zb-chip-v">' . zb_h($it)
                    . '</span><i class="fa fa-times zb-chip-x" role="button" aria-label="Entfernen"></i></span>';
        }
        $empty = '<span class="zb-list-empty"' . ($items ? ' style="display:none"' : '') . '>– keine Einträge –</span>';
        return '<span class="zb-list">'
             . '<span class="zb-chips">' . $empty . $chips . '</span>'
             . '<span class="zb-list-add"><input type="text" class="zb-list-input" placeholder="Dataset hinzufügen, z. B. tank/data">'
             . '<button type="button" class="zb-list-addbtn">Hinzufügen</button></span>'
             . '<input type="hidden" data-name="' . zb_a($name) . '" data-type="array" data-orig="' . zb_a($joined) . '" value="' . zb_a($joined) . '">'
             . '</span>';
    }
    if ($isSecret) {
        $set = ($cur === '***');
        return '<input type="password" autocomplete="new-password" data-name="' . zb_a($name) . '" data-type="secret" data-orig=""'
             . ' value="" placeholder="' . ($set ? 'gesetzt – leer lassen, um zu behalten' : 'nicht gesetzt') . '">';
    }
    return zb_input('data-name', $name, 'string', (string)($cur ?? ''));
}

/* Rendert einen Markdown-String über Unraids eigenen Konverter zu HTML (native
 * Inline-Hilfe inklusive). Unraids markdown="1"-Auto-Processing läuft VOR PHP und
 * greift bei per PHP erzeugtem Markup nicht – daher der direkte Aufruf. */
function zb_md(string $md): string {
    if (!function_exists('Markdown')) {
        $f = '/usr/local/emhttp/plugins/dynamix/include/Markdown.php';
        if (is_file($f)) require_once $f;
    }
    return function_exists('Markdown') ? Markdown($md) : '<pre>' . zb_h($md) . '</pre>';
}

/* Markdown-Schnipsel für eine beschriftete Zeile (Label als Term, Eingabefeld als
 * dd, Hinweis als Blockquote -> native Unraid-Inline-Hilfe). Eingabefeld muss eine
 * EINZEILIGE HTML-Zeichenkette sein. */
function zb_ed_md(string $label, string $hint, string $inputHtml): string {
    $s = $label . ":\n: " . $inputHtml . ' <span class="fieldmsg"></span>' . "\n";
    if ($hint !== '') {
        $s .= "\n> " . preg_replace('/\s+/', ' ', $hint) . "\n";
    }
    return $s . "\n";
}

// EIN Aggregat-Aufruf statt fünf Einzelaufrufen (ein Interpreter-Start statt
// fünf) – spürbar schnellerer Seitenaufbau. Liefert Status, Kapazität (cached),
// Schema, Konfigwerte und Ziele in einem JSON-Objekt.
list($gui, $rc) = zb_json('--gui-init --json');
if (!is_array($gui)) { $gui = []; }
$st      = $gui['status']   ?? null;
$cap     = $gui['capacity'] ?? null;
$schema  = $gui['schema']   ?? null;
$values  = $gui['values']   ?? null;
$targets = $gui['targets']  ?? null;

/* CSRF-Token für den Speicher-Endpoint. In Unraid-Seiten stellt der PageBuilder
 * das geparste var.ini als globales $var bereit – das ist die zuverlässige
 * Quelle (eigenes Datei-Lesen scheitert hier u. U. an open_basedir). */
global $var;
$csrf = $var['csrf_token'] ?? '';
?>

