            . '<select id="sch-hour">' . $hourOpts . '</select> :'
            . '<select id="sch-minute">' . $minOpts . '</select></span>');
  $smd .= zb_ed_md('Wochentag',
            'Nur bei „Wöchentlich".',
            '<select id="sch-dow">' . $dowOpts . '</select>');
  $smd .= zb_ed_md('Minute',
            'Nur bei „Stündlich" – zu welcher Minute der Stunde.',
            '<select id="sch-min">' . $minOpts . '</select>');
  $smd .= zb_ed_md('Cron-Ausdruck',
            'Fünf Felder: Minute Stunde Tag Monat Wochentag. Bei den Presets automatisch berechnet, bei „Benutzerdefiniert" frei editierbar.',
            '<input type="text" id="sch-cron" placeholder="z. B. 0 2 * * *" readonly>');
?>
  <div id="zb-schedule-form"><?= zb_md($smd) ?></div>
