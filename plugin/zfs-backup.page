            'Alle Logdateien entfernen.',
            zb_maint_btn('delete-logs', 'Logs löschen', 'Löschen',
              'Alle Logdateien wirklich löschen?', true));
  $mmd .= zb_ed_md('Verwaiste Datasets löschen',
            'Entfernt Ziel-Datasets, deren Quell-Dataset nicht mehr existiert (zfs destroy -r). Nach dem Klick wählst du das Ziel, danach folgt die Bestätigung. Vorher unbedingt „Verwaiste Datasets anzeigen" prüfen!',
            zb_maint_btn('cleanup-orphans', 'Verwaiste Datasets löschen', 'Löschen',
