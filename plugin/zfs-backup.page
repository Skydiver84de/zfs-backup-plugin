            zb_maint_btn('cleanup-orphans-dry', 'Verwaiste Datasets (Dry-Run)', 'Anzeigen'));

  // Wartung (destruktiv): zusätzlich data-confirm + roter Knopf.
  $mmd .= "#### Wartung\n\n";
  $mmd .= zb_ed_md('Statistiken zurücksetzen',
            'Gespeicherte Laufstatistiken löschen.',
            zb_maint_btn('reset-statistics', 'Statistiken zurücksetzen', 'Zurücksetzen',
              'Gespeicherte Laufstatistiken wirklich löschen?', true));
  $mmd .= zb_ed_md('Laufstatus zurücksetzen',
